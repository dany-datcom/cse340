<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><strong><%= organization.name %></strong>: <p><%= organization.description %></p><p>Email: <%= organization.contact_email %></p></li>
            <% }); %>
        </ul>
    </main>
    <%- include('partials/footer') %>