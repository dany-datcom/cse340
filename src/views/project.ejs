<%- include('partials/header') %>
    <main>

        <h1>
            <%= project.title %>
        </h1>

        <p>
            <%= project.description %>
        </p>
        <p>
            <%= project.date %>
        </p>
        <p>
            <%= project.location %>
        </p>

        <p>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>
        <div>
            <% categories.forEach(cat=> { %>
                <a href="/category/<%= cat.id %>">
                    #<%= cat.name %>
                </a>
                <% }) %>
        </div>

    </main>
    </body>
    <%- include('partials/footer') %>